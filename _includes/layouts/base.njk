<!doctype html>
<html lang="nl-nl">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes">

    <title>{{ renderData.title or title or metadata.title }}</title>

    <meta name="Description" content="{{ renderData.description or description or metadata.description }}">

    <link href="https://fonts.googleapis.com/css?family=PT+Serif:400,400i,700,700i" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="{{ '/css/index.css' | url }}">
    <link rel="stylesheet" type="text/css" href="{{ '/css/prism-base16-monokai.dark.css' | url }}">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">
  </head>
  <body class="site-container flow">
    <header class="pagehead">
      <div class="pagehead-content">
        <a class="logo" href="{{ '/' | url }}">{{ metadata.title }}</a>
        {# <nav class="top-nav">
          <ul class="list-inline">
            {%- for nav in collections.nav | reverse -%}
            <li class="list-inline-item top-nav__item{% if nav.url == page.url %} top-nav__item--active{% endif %}">
              <a class="top-nav__link" href="{{ nav.url | url }}">{{ nav.data.navtitle }}</a>
            </li>
            {%- endfor -%}
          </ul>
        </nav> #}
      </div>
    </header>
    <main class="main flow{% if templateClass %} {{ templateClass }}"{% endif %}>
      {{ content | safe }}
    </main>
    <footer class="pagefoot">
      &copy; {{ renderData.title or title or metadata.title }} 2019
    </footer>
    <!-- Current page: {{ page.url | url }} -->
  </body>
</html>
